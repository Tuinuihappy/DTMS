# DTMS local environment overrides.
#
# Copy this file to `.env` (which is git-ignored) and fill in the real
# values from your secrets store. docker-compose substitutes these into
# the api service env block via the ${VAR:-default} syntax.
#
# In production, source these from Vault / AWS Secrets Manager / Doppler
# instead of a plain file.

# ── RIOT3 vendor (required for live integration) ───────────────────────
# Format: "app <jwt>". Obtain from RIOT3 ops team.
# Used by every Riot3 HTTP client + the vendor health probe.
VendorAdapter__Riot3__ApiKey=

# ── Upstream OMS (required if UpstreamOms__Enabled=true) ───────────────
# Long-lived RS256 JWT supplied by OMS ops. Rotate by replacing this
# value and restarting the api service.
UpstreamOms__BearerToken=

# ── External Auth RSA public key (required) ────────────────────────────
# PKCS#1 base64 public key from the External Auth service
# (http://10.204.212.28:15000). Used to verify JWT signatures only —
# per ADR-014, DTMS doesn't sign its own tokens. Obtain from auth ops.
Jwt__PublicKey=

# ── RIOT3 inbound webhook auth (defaults are off — set when going prod) ─
VendorAdapter__Riot3__Webhook__RequireAuth=false
VendorAdapter__Riot3__Webhook__AllowedIPs__0=
VendorAdapter__Riot3__Webhook__UrlSecrets__0=
VendorAdapter__Riot3__Webhook__UrlSecrets__1=

# ── Optional overrides (sensible defaults baked into compose) ──────────
# Cors__HubsAllowedOrigins=http://localhost:3000,http://localhost:3001
# RateLimit__PermitLimit=100
# RateLimit__WindowSeconds=60
# RateLimit__QueueLimit=5
# UpstreamOms__Enabled=true
# UpstreamOms__BaseUrl=http://10.204.37.65:5002/
# UpstreamOms__TimeoutSeconds=10
# Dispatch__UseOrderTemplateDispatch=false
# Workflow__UseSaga=false
# Outbox__UseSkipLocked=false
# Outbox__PublishConcurrency=1
# PlanningWatchdog__Enabled=true
# PlanningWatchdog__PollIntervalSeconds=60
# PlanningWatchdog__StaleThresholdSeconds=120
# Dispatch__Reconciliation__Enabled=true
# Dispatch__Reconciliation__PollIntervalSeconds=60
# Dispatch__Reconciliation__StaleThresholdHours=24
# DTMS_AUTH_BYPASS=false
# DTMS_API_BASE_URL=http://10.204.212.28:15000
# DTMS_BACKEND_URL=http://dtms-api:8080
# NEXT_PUBLIC_DTMS_HUBS_URL=http://localhost:5219
