{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "",
    "Password": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "VendorAdapter": {
    "Riot3": {
      "BaseUrl": "http://localhost:5100",
      "ApiKey": "",
      "RouteSync": {
        "IntervalMinutes": 30
      }
    }
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "AMR.DeliveryPlanning",
    "Audience": "AMR.DeliveryPlanning.Api",
    "ExpirationMinutes": 60
  },
  "AllowedHosts": "*"
}
