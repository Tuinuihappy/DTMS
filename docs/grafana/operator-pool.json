    {
      "type": "stat",
      "title": "Pool depth (now)",
      "description": "Trips available in the pool right now. Alerts fire when >50 for 5m.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "dtms_pool_depth", "legendFormat": "depth", "refId": "A" }
