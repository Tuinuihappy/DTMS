# Copy to .env.local. The Next.js dev server reads .env.local automatically.
#
# Empty (default) means the frontend hits its own origin and relies on the
# rewrite in next.config.ts to forward /api/* to the DTMS backend. If you
# need to point at a different backend host, set the value here AND drop
# the rewrite, otherwise both layers will fight.

NEXT_PUBLIC_API_BASE=
