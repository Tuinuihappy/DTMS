# syntax=docker/dockerfile:1.7
#
# Multi-stage build for the TMS dashboard.
# Produces a slim Node-based runtime that runs the Next.js standalone
# server — no node_modules at runtime, only what @vercel/nft traced.
#
# Build from this directory (recommended):
#   docker build -t tms-frontend -f Dockerfile .
#
# Or from the repo root via compose:
#   docker compose --profile prod up -d --build frontend
#
# The final image listens on $PORT (default 3000) and runs as a
# non-root user.

ARG NODE_VERSION=22-alpine

# ── deps stage ────────────────────────────────────────────────────────
# Installs production + dev deps using package-lock.json for a
# reproducible install. Cached layer — only re-runs when the lockfile
# or package.json changes.
FROM node:${NODE_VERSION} AS deps
WORKDIR /app

# libc6-compat is needed for some Node native modules on Alpine
# (sharp, swc binaries, etc.).
RUN apk add --no-cache libc6-compat

COPY package.json package-lock.json* ./
RUN npm ci --no-audit --no-fund

# ── builder stage ─────────────────────────────────────────────────────
# Runs `next build` with the standalone output. Telemetry is disabled
# so the image build doesn't try to phone Vercel.
FROM node:${NODE_VERSION} AS builder
WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npm run build

# ── runner stage ──────────────────────────────────────────────────────
# Minimal image: only the standalone bundle + public + .next/static.
# Runs as a non-root user.
FROM node:${NODE_VERSION} AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Same lib as deps stage for any runtime native code.
RUN apk add --no-cache libc6-compat curl \
 && addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs

# Public assets (favicon etc.) live outside the standalone trace.
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

# Standalone bundle: server.js + minimal node_modules trace.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
# Static chunks served by server.js.
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -fsS http://127.0.0.1:${PORT}/ >/dev/null || exit 1

# server.js is generated by `next build` when output is "standalone".
CMD ["node", "server.js"]
