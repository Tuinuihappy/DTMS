# DTMS load-test environment — full safe config for perf scenario B
#
# Usage:
#   docker compose --env-file .env.test up -d --force-recreate api
#
# When loaded, the api boot log MUST show:
#   [Composition] IRobotOrderDispatcher = NoOpOrderDispatcherAdapter
#   [Composition] IRiot3OrderQueryService = NoOpRiot3OrderQueryService
#   OutboxProcessorService started (UseSkipLocked=True, BatchSize=500, PublishConcurrency=8, PollIntervalSeconds=1, ...)
#
# If any line is missing, STOP the test — env vars didn't load.

# ── Outbox tuning (Phase A A1+A2+A3+A4) ──────────────────────────────────
Outbox__UseSkipLocked=true
Outbox__BatchSize=500
Outbox__PollIntervalSeconds=1
Outbox__PublishConcurrency=8
Outbox__PerMessageTimeoutSeconds=10

# ── Rate limit lifted to expose backend ceilings ─────────────────────────
# Same setup as the 2026-06-16 perf baseline so apples-to-apples comparison
# remains valid. NEVER push these values to production — they remove the
# per-IP throttling that protects the API.
RateLimit__PermitLimit=100000
RateLimit__WindowSeconds=1
RateLimit__QueueLimit=5000

# ── Vendor isolation — ZERO RIOT3 outbound traffic ───────────────────────
# Both flags below must be false during load tests. Either one alone leaves
# a leak:
#   - VendorAdapter:Riot3:Enabled=false swaps IRobotOrderDispatcher (POST
#     orders) AND IRiot3OrderQueryService (reconciler GETs) to NoOp impls
#   - Dispatch:Reconciliation:Enabled=false stops the reconciler tick
#     entirely (belt + suspenders — even if a future code path bypasses
#     NoOp, the tick itself doesn't fire)
VendorAdapter__Riot3__Enabled=false
Dispatch__Reconciliation__Enabled=false

# ── Phase D — outbox-worker container split (load test) ──────────────────
# When loading .env.test the assumption is BOTH api and outbox-worker
# containers are running. API hands off outbox drain entirely to the
# worker so HTTP throughput is uncontested. Worker container's hardcoded
# Outbox__RunInThisProcess=true ensures it still drains.
Outbox__RunInThisProcess=false
